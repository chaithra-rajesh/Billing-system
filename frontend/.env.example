# All frontend env is public — every var is exposed to the browser.
# The service-role key NEVER appears here. It lives only on the backend.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL where Supabase Edge Functions are reachable from the browser.
# Local: http://127.0.0.1:54321/functions/v1
# Prod:  https://<project-ref>.supabase.co/functions/v1
NEXT_PUBLIC_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
