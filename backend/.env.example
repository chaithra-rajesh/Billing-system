# ============================================================
# Backend env. Server-only. None of these values reach the browser.
# ============================================================

# Project URL — same value the frontend uses, just here for backend tooling/scripts.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Anon (publishable) key — safe to share, but the frontend reads its own copy.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Service-role key. NEVER commit. NEVER copy into the frontend repo.
# Used by privileged scripts and (rarely) by edge functions that need to bypass RLS
# for system maintenance. Most edge functions use the caller's JWT instead.
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# JWT secret — used to verify incoming JWTs in edge functions when not relying
# on supabase-js to do it for us.
NEXT_PUBLIC_SUPABASE_JWT_SECRET=replace-with-local-jwt-secret

# DB connection — used by raw SQL scripts (psql, migration tools).
# Local default printed by `supabase start`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Comma-separated origins allowed to call Edge Functions (read by _shared/cors.ts).
# Local: http://localhost:3000
# Prod:  https://billing-app.pages.dev,https://<your-custom-domain>
# Set in Supabase via: supabase secrets set ALLOWED_ORIGINS="https://billing-app.pages.dev"
ALLOWED_ORIGINS=http://localhost:3000

# Optional: webhook signing secrets for PSPs. Add as we integrate.
# STRIPE_WEBHOOK_SECRET=
